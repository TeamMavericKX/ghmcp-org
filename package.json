{
  "name": "ghmcp-org",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant GitHub MCP server for AI agents",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm run build:core && pnpm run build:http && pnpm run build:stdio",
    "build:core": "pnpm --filter @ghmcp-org/core run build",
    "build:http": "pnpm --filter @ghmcp-org/server-http run build",
    "build:stdio": "pnpm --filter @ghmcp-org/server-stdio run build",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm --filter @ghmcp-org/core run test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:http": "pnpm run build:core && tsx watch apps/server-http/src/index.ts",
    "dev:stdio": "pnpm run build:core && tsx apps/server-stdio/src/index.ts",
    "docs:tools": "tsx scripts/gen-tools-md.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "cspell": "^10.0.1",
    "lefthook": "^2.1.9",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
